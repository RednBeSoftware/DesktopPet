<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DesktopPet.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        x:Class="DesktopPet.Views.ChatWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="DesktopPet Chat"
        CanResize="True"
        Width="400"
        Height="500">
    
    <Grid RowDefinitions="*,Auto">
        <!-- Chat Messages ScrollViewer -->
        <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="0" Margin="0">
            <StackPanel x:Name="ChatPanel" Margin="10"/>
        </ScrollViewer>
        
        <!-- Input Area -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="10" Background="Black">
            <TextBox x:Name="InputTextBox" 
                     Grid.Column="0" 
                     Watermark="Type your message..."
                     Margin="0,0,5,0"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"/>
            <Button x:Name="SendButton"
                    Background="Black"
                    Grid.Column="1" 
                    Content="Send"
                    Width="60"
                    BorderBrush="White"
                    BorderThickness="1"/>
        </Grid>
    </Grid>
</Window>